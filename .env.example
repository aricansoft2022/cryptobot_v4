# cryptobot — ortam değişkenleri şablonu
#
# Kullanım: bu dosyayı ".env" olarak kopyala ve değerleri doldur.
#   cp .env.example .env
#
# .env dosyası .gitignore'dadır; ASLA commit edilmez (gizli anahtarlar içerir).
# Bu değişkenler yalnızca CANLI mod (--live) için gereklidir; kağıt/backtest
# modu anahtar istemez. Kabuk (shell) ortamında zaten tanımlıysa o değer önceliklidir.

BINANCE_API_KEY=
BINANCE_API_SECRET=
